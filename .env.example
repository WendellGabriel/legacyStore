# ==========================================
# Supabase (frontend - valores PÚBLICOS, seguros para o navegador)
# ==========================================
# Encontre em: Supabase Dashboard > Project Settings > API
NG_APP_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NG_APP_SUPABASE_ANON_KEY=sua-anon-key-publica

# ==========================================
# Backend / Supabase (SECRETO - NUNCA expor no frontend nem commitar)
# ==========================================
# service_role bypassa RLS. Use apenas no backend.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-secreta
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.SEU-PROJETO.supabase.co:5432/postgres
