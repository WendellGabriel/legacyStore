# Ignora scripts de instalação globalmente — faz TODO "pnpm install" sair com
# sucesso (inclusive o interno da Vercel ao montar as functions), evitando o
# ERR_PNPM_IGNORED_BUILDS. Seguro: os binários nativos (esbuild, @parcel/watcher,
# lmdb, msgpackr-extract) vêm pré-compilados via deps opcionais no Linux.
ignore-scripts=true

# Não re-verificar dependências antes de rodar scripts (pnpm).
verify-deps-before-run=false
