{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": ["/favicon.ico", "/index.html", "/manifest.webmanifest", "/*.css", "/*.js"]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/icon.svg", "/brand/**", "/media/**", "/*.(svg|png|jpg|jpeg|webp|woff2)"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "supabase-catalog",
      "urls": ["https://oratzgtadilcozstexec.supabase.co/rest/v1/products*", "https://oratzgtadilcozstexec.supabase.co/rest/v1/categories*"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 100,
        "maxAge": "1h",
        "timeout": "3s"
      }
    }
  ]
}
