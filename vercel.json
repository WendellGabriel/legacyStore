{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "pnpm install || true",
  "buildCommand": "pnpm --filter web build",
  "outputDirectory": "apps/web/dist/web/browser",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'none'; upgrade-insecure-requests"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://oratzgtadilcozstexec.supabase.co/functions/v1/store-api/sitemap.xml"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://oratzgtadilcozstexec.supabase.co/functions/v1/store-api/$1"
    },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
