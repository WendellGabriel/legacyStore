{
  "name": "legacystore",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "web": "pnpm --filter web",
    "api": "pnpm --filter api",
    "dev:web": "pnpm --filter web start",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,html,scss,json,md}\""
  },
  "dependencies": {
    "@legacystore/shared": "workspace:*",
    "@supabase/supabase-js": "^2.47.10",
    "hono": "^4.6.14",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@angular/cli": "^22.0.6",
    "prettier": "^3.3.3"
  }
}
